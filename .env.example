# ============================================
# SWELLS LAB - Environment Variables
# ============================================
# 1. Copy this file to .env.local
# 2. Fill in your Supabase project values below
# 3. NEVER commit .env.local to git
# ============================================

# Supabase - get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_public_key_here

# ============================================
# NOTE: The Airtable PAT does NOT go here.
# It lives in Supabase Edge Function secrets.
# See README.md for instructions.
# ============================================
